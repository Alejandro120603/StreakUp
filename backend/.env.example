# Flask runtime
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=true

# Security
# In non-development runtimes both secrets must be unique and at least 32 chars.
SECRET_KEY=replace-with-strong-secret-at-least-32-characters
JWT_SECRET_KEY=replace-with-strong-jwt-secret-at-least-32-characters

# Persistence
# Local dev defaults to data/app.db when DATABASE_URL is omitted.
# Render-style Postgres URLs are normalized automatically.
DATABASE_URL=postgresql://user:password@host:5432/streakup
PORT=5000

# Browser clients in non-development runtimes must be allow-listed explicitly.
CORS_ALLOWED_ORIGINS=https://app.example.com,https://streakup.example.com

# OpenAI
# Optional. If omitted, the backend still boots but photo validation returns 503 and
# /readyz reports validation.status=not_configured.
OPENAI_API_KEY=your-openai-api-key-here
